# Copy to ".env" (gitignored) and fill in. Used by python-dotenv when starting the API.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@example.com
SMTP_PASSWORD=your-16-char-app-password-no-spaces
SMTP_FROM_EMAIL=your.email@example.com
SMTP_FROM_NAME=DZRESEARCH-CONNECT

# Optional: weekly digest batch protection
# DIGEST_CRON_SECRET=change-me

# Legacy: if SMTP_FROM_EMAIL is unset, this address is used as From
# SMTP_FROM=
